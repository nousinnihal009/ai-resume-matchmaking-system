# =============================================================================
# AI Resume Matchmaking System - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the application.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=resume_matcher
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@db:5432/resume_matcher

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Application Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# ML Pipeline Configuration
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# OPENAI_API_KEY=sk-... (optional, for OpenAI embeddings)

# -----------------------------------------------------------------------------
# File Upload
# -----------------------------------------------------------------------------
UPLOAD_DIRECTORY=./uploads
# MAX_FILE_SIZE=5242880  # 5MB in bytes
