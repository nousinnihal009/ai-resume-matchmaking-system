# ==========================================================================
# AI Resume Matchmaking System — Environment Variables
# ==========================================================================
# Copy this file to .env and fill in all values marked CHANGE_ME.
# NEVER commit .env to version control — it is listed in .gitignore.
# ==========================================================================

# --- Database ---------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=resume_matcher
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@db:5432/resume_matcher

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- Security ---------------------------------------------------------------
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Application ------------------------------------------------------------
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Frontend (Vite) --------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_USE_MOCK=false

# --- ML Pipeline ------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_CACHE_DIR=/app/.model_cache
EMBEDDING_BATCH_SIZE=32
# OPENAI_API_KEY=sk-...   (optional — only needed for OpenAI embeddings)

# --- File Upload ------------------------------------------------------------
UPLOAD_DIRECTORY=./uploads
# MAX_FILE_SIZE=5242880   (5 MB in bytes)

# --- Sentry Error Monitoring ----------------------------------------
# Get your DSN from https://sentry.io → Project → Settings → SDK Setup
# Leave empty to disable Sentry in local development
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
